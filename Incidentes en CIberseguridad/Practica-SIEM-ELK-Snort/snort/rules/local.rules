# =============================================================
# Reglas locales de detección — SIEM Lab
# Sintaxis compatible con Suricata y Snort
# =============================================================

# REGLA 1 — Detección de tráfico ICMP (ping)
# Alerta cuando cualquier host envíe un ping (itype:8 = echo request)
# hacia cualquier máquina de nuestra red HOME_NET
# sid:1000001 → identificador único de la regla
alert icmp any any -> $HOME_NET any (msg:"SIEM ALERT: ICMP ping detectado"; itype:8; sid:1000001; rev:1;)

# REGLA 2 — Detección de fuerza bruta SSH
# Alerta cuando una misma IP origine más de 5 paquetes SYN al puerto 22
# en un intervalo de 60 segundos (patrón típico de Hydra/Medusa)
# detection_filter → no alerta en el primer intento, espera al umbral
alert tcp any any -> $HOME_NET 22 (msg:"SIEM ALERT: Posible ataque fuerza bruta SSH"; flags:S; detection_filter:track by_src, count 5, seconds 60; sid:1000002; rev:1;)
