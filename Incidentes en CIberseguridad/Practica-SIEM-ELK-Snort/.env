# ============================================================
# SIEM Lab — Variables de Entorno
# ============================================================
ELASTIC_VERSION=8.15.3

# Red Docker (172.17-172.26 ocupadas por otros proyectos en este host)
SIEM_SUBNET=172.30.0.0/24
ES_IP=172.30.0.10
KIBANA_IP=172.30.0.11
LOGSTASH_IP=172.30.0.12
SNORT_IP=172.30.0.20

# Puertos expuestos en el host
ES_PORT=9200
KIBANA_PORT=5601
LOGSTASH_BEATS_PORT=5044

# JVM Heap (1g para cada nodo, ajustar si RAM < 4 GB)
ES_JAVA_OPTS=-Xms1g -Xmx1g
LS_JAVA_OPTS=-Xms512m -Xmx512m
